{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "FETCHCONTENT_BASE_DIR":             "${sourceDir}/.deps",
        "FETCHCONTENT_UPDATES_DISCONNECTED": "ON"
      }
    },
    {
      "name": "base_arm_gnu_gcc",
      "hidden": true,
      "inherits": "base",
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/toolchain/arm-gnu-gcc.cmake"
    },
    {
      "name": "base_arm_gnu_gcc_release",
      "hidden": true,
      "inherits": "base_arm_gnu_gcc",
      "binaryDir": "${sourceDir}/build/arm_gnu_gcc_release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "base_arm_gnu_gcc_debug",
      "hidden": true,
      "inherits": "base_arm_gnu_gcc",
      "binaryDir": "${sourceDir}/build/arm_gnu_gcc_debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ]
}
